rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isString(value) {
      return value is string && value.size() > 0;
    }

    function isNumber(value) {
      return value is number;
    }

    function isValidSuperAdminSeed() {
      return request.resource.data.keys().hasOnly([
        'id',
        'name',
        'code',
        'registrations',
        'todayDeposits',
        'monthDeposits',
        'todayWithdrawals',
        'monthWithdrawals',
        'username',
        'password',
        'role'
      ])
      && request.resource.data.id == 'a0'
      && request.resource.data.name == 'Super Admin'
      && request.resource.data.code == '000001'
      && request.resource.data.username == 'superadmin'
      && request.resource.data.password == 'super123'
      && request.resource.data.role == 'super_admin'
      && isNumber(request.resource.data.registrations)
      && isNumber(request.resource.data.todayDeposits)
      && isNumber(request.resource.data.monthDeposits)
      && isNumber(request.resource.data.todayWithdrawals)
      && isNumber(request.resource.data.monthWithdrawals);
    }

    match /admins/{adminId} {
      allow read: if true;
      allow create: if adminId == 'a0'
        && !exists(/databases/$(database)/documents/admins/a0)
        && isValidSuperAdminSeed();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
